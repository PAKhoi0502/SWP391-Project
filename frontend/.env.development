# Base URL cho API.
# Để trống ở môi trường dev => axios gọi đường dẫn tương đối ("/api...", "/health")
# và Vite proxy sẽ forward về http://localhost:8080 (xem vite.config.js).
VITE_API_BASE_URL=

# Google OAuth Client ID — điền sau khi tạo ở console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=966960784834-50fmlj22jaepnfg60ci2qhlv7ppch5hq.apps.googleusercontent.com
