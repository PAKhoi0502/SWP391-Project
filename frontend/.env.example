# Sao chép file này thành .env.development (hoặc .env) và điều chỉnh nếu cần.
#
# Dev: để trống => dùng Vite proxy về http://localhost:8080
# Prod: điền URL backend thật, ví dụ: https://api.autowashpro.com
VITE_API_BASE_URL=

# Google OAuth Client ID (console.cloud.google.com/apis/credentials) — dùng cho nút "Sign in with Google"
VITE_GOOGLE_CLIENT_ID=
